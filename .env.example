# ── Aplicación ─────────────────────────────────────────────
APP_ENV=development
APP_NAME=PrecioSV
APP_VERSION=1.0.0
SECRET_KEY=cambia-esto-por-una-clave-segura-en-produccion
DEBUG=true

# ── Base de datos ───────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://preciosv:preciosv123@localhost:5432/preciosv_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis & Celery ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Scraping ────────────────────────────────────────────────
SCRAPER_DELAY_SECONDS=1.5
SCRAPER_MAX_RETRIES=3
SCRAPER_TIMEOUT_SECONDS=30
SCRAPER_HEADLESS=true

# ── IA (Claude API) ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-tu-api-key-aqui
MATCHING_MODEL=claude-sonnet-4-6
MATCHING_ENABLED=true

# ── Email (SendGrid) ────────────────────────────────────────
SENDGRID_API_KEY=SG.tu-api-key-aqui
EMAIL_FROM=alertas@preciosv.com
EMAIL_FROM_NAME=PrecioSV

# ── CORS ────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://preciosv.com

# ── Programación de scrapers ────────────────────────────────
SCRAPE_INTERVAL_HOURS=6
SCRAPE_START_HOUR=0
